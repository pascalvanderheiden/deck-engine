    "modern-screenshot": "^4.6.8"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.38.0",
    "puppeteer-core": "^24.38.0"
  }
