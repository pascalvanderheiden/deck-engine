{
  "name": "@deckio/deck-engine",
  "version": "1.7.8",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deckio-art/deck-engine.git",
    "directory": "packages/deck-engine"
  },
  "main": "./index.js",
  "module": "./index.js",
  "exports": {
